# --- Server-only secrets (set these in Vercel → Project → Settings → Environment Variables) ---

# Get this from https://resend.com/api-keys after verifying the mail subdomain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender + reply-to. Keep these unless you rename the domain.
MAIL_FROM=notifications@uni-hitch-match.win
MAIL_REPLY_TO=hello@uni-hitch-match.win

# Public site URL, used inside the email footer.
SITE_URL=https://uni-hitch-match.win

# Supabase (serverless routes under /api — use non-VITE names; never commit service_role key)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# --- Client-side (VITE_ vars are inlined into the bundle — do NOT put secrets here) ---

# Optional: override the serverless endpoint during local testing.
# Leave unset in production; defaults to /api/send-interest on the same origin.
# VITE_SEND_INTEREST_ENDPOINT=/api/send-interest

# After wiring Supabase Auth in the SPA:
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
